{
  "name": "wage-sage",
  "displayName": "Wage Sage",
  "version": "0.0.1",
  "description": "Salary negotiation powered by BLS data and AI",
  "author": "Jason Zeng",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.6.2",
    "@plasmohq/storage": "^1.13.0",
    "plasmo": "^0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "^22.12.0",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.0",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.0",
    "typescript": "5.3.3",
    "vitest": "^3.1.1"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "storage"
    ],
    "host_permissions": [
      "https://www.linkedin.com/*",
      "https://api.bls.gov/*"
    ]
  }
}
